@article{huCellCycleDynamics2019,
  title = {Cell Cycle Dynamics in the Reprogramming of Cellular Identity},
  author = {Hu, Xiao and Eastman, Anna E. and Guo, Shangqin},
  date = {2019},
  journaltitle = {FEBS Letters},
  volume = {593},
