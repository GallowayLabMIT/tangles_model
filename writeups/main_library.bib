@article{sethiSupervisedEnhancerPrediction2020,
  title = {Supervised Enhancer Prediction with Epigenetic Pattern Recognition and Targeted Validation},
  author = {Sethi, Anurag and Gu, Mengting and Gumusgoz, Emrah and Chan, Landon and Yan, Koon-Kiu and Rozowsky, Joel and Barozzi, Iros and Afzal, Veena and Akiyama, Jennifer A. and Plajzer-Frick, Ingrid and Yan, Chengfei and Novak, Catherine S. and Kato, Momoe and Garvin, Tyler H. and Pham, Quan and Harrington, Anne and Mannion, Brandon J. and Lee, Elizabeth A. and Fukuda-Yuzawa, Yoko and Visel, Axel and Dickel, Diane E. and Yip, Kevin Y. and Sutton, Richard and Pennacchio, Len A. and Gerstein, Mark},
