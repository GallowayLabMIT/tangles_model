@article{feliuSERSQuantificationCharacterization2017,
  title = {{{SERS Quantification}} and {{Characterization}} of {{Proteins}} and {{Other Biomolecules}}},
  author = {Feliu, Neus and Hassan, Moustapha and Garcia Rico, Eduardo and Cui, Daxiang and Parak, Wolfgang and Alvarez-Puebla, Ramon},
