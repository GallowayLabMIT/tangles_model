  author = {Goldstein, Dora B},
  date = {1986-09-01},
  journaltitle = {Annals of Emergency Medicine},
  shortjournal = {Annals of Emergency Medicine},
  series = {Proceedings of the 1986 {{UAEM}}/{{IRIEM Research Symposium}} on {{Toxicology}}},
  volume = {15},
