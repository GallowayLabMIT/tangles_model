@article{dinhDevelopmentQuorumSensingBased2020,
  title = {Development of a {{Quorum-Sensing Based Circuit}} for {{Control}} of {{Coculture Population Composition}} in a {{Naringenin Production System}}},
  author = {Dinh, Christina V. and Chen, Xingyu and Prather, Kristala L. J.},
