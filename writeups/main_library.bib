@article{coomerNoiseDistortsEpigenetic2021,
  title = {Noise Distorts the Epigenetic Landscape and Shapes Cell-Fate Decisions},
  author = {Coomer, Megan A. and Ham, Lucy and Stumpf, Michael P. H.},
  date = {2021-10-08},
  journaltitle = {Cell Systems},
