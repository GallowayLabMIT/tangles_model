@article{palmaDissectingVivoDynamics2020,
  title = {Dissecting the in Vivo Dynamics of Transcription Locking Due to Positive Supercoiling Buildup},
  author = {Palma, Cristina S. D. and Kandavalli, Vinodh and Bahrudeen, Mohamed N. M. and Minoia, Marco and Chauhan, Vatsala and Dash, Suchintak and Ribeiro, Andre S.},
