@article{beitzSyntheticGeneCircuits2022,
  title = {Synthetic Gene Circuits as Tools for Drug Discovery},
  author = {Beitz, Adam M. and Oakes, Conrad G. and Galloway, Kate E.},
  date = {2022-02-01},
  journaltitle = {Trends in Biotechnology},
