@article{gaidukovMultilandingPadDNA2018,
  title = {A Multi-Landing Pad {{DNA}} Integration Platform for Mammalian Cell Engineering},
  author = {Gaidukov, Leonid and Wroblewska, Liliana and Teague, Brian and Nelson, Tom and Zhang, Xin and Liu, Yan and Jagtap, Kalpana and Mamo, Selamawit and Tseng, Wen Allen and Lowe, Alexis and Das, Jishnu and Bandara, Kalpanie and Baijuraj, Swetha and Summers, Nevin M and Lu, Timothy K and Zhang, Lin and Weiss, Ron},
