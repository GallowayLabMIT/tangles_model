@article{hsiehResolving3DLandscape2019,
  title = {Resolving the {{3D}} Landscape of Transcription-Linked Mammalian Chromatin Folding},
  author = {Hsieh, Tsung-Han S. and Slobodyanyuk, Elena and Hansen, Anders S. and Cattoglio, Claudia and Rando, Oliver J. and Tjian, Robert and Darzacq, Xavier},
