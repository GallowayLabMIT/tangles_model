@article{picelliTn5TransposaseTagmentation2014,
  title = {Tn5 Transposase and Tagmentation Procedures for Massively Scaled Sequencing Projects},
  author = {Picelli, Simone and Björklund, Åsa K. and Reinius, Björn and Sagasser, Sven and Winberg, Gösta and Sandberg, Rickard},
