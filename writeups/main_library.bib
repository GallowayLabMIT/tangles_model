@article{oudelaarDynamics4DGenome2020,
  title = {Dynamics of the {{4D}} Genome during in Vivo Lineage Specification and Differentiation},
  author = {Oudelaar, A. Marieke and Beagrie, Robert A. and Gosden, Matthew and de Ornellas, Sara and Georgiades, Emily and Kerry, Jon and Hidalgo, Daniel and Carrelha, Joana and Shivalingam, Arun and El-Sagheer, Afaf H. and Telenius, Jelena M. and Brown, Tom and Buckle, Veronica J. and Socolovsky, Merav and Higgs, Douglas R. and Hughes, Jim R.},
  options = {useprefix=true},
