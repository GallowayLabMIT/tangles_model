@article{shinSingleLentiviralVector2006,
  title = {A Single Lentiviral Vector Platform for {{microRNA-based}} Conditional {{RNA}} Interference and Coordinated Transgene Expression},
  author = {Shin, Kum-Joo and Wall, Estelle A. and Zavzavadjian, Joelle R. and Santat, Leah A. and Liu, Jamie and Hwang, Jong-Ik and Rebres, Robert and Roach, Tamara and Seaman, William and Simon, Melvin I. and Fraser, Iain D. C.},
