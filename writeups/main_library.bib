@article{duportetPlatformRapidPrototyping2014,
  title = {A Platform for Rapid Prototyping of Synthetic Gene Networks in Mammalian Cells},
  author = {Duportet, Xavier and Wroblewska, Liliana and Guye, Patrick and Li, Yinqing and Eyquem, Justin and Rieders, Julianne and Rimchala, Tharathorn and Batt, Gregory and Weiss, Ron},
