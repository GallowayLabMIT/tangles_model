  langid = {english},
  file = {C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\EJMHS3DP\\Oudelaar et al_2020_Dynamics of the 4D genome during in vivo lineage specification and.pdf;C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\UYLE8M7B\\s41467-020-16598-7.html}
}

@article{ovchinnikovRoleFrameworkMutations2018,
  title = {Role of Framework Mutations and Antibody Flexibility in the Evolution of Broadly Neutralizing Antibodies},
  author = {Ovchinnikov, Victor and Louveau, Joy E and Barton, John P and Karplus, Martin and Chakraborty, Arup K},
  date = {2018-02-14},
