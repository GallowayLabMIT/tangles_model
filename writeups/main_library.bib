@article{duchiRNAPolymerasePausing2016,
  title = {{{RNA Polymerase Pausing}} during {{Initial Transcription}}},
  author = {Duchi, Diego and Bauer, David~L.V. and Fernandez, Laurent and Evans, Geraint and Robb, Nicole and Hwang, Ling~Chin and Gryte, Kristofer and Tomescu, Alexandra and Zawadzki, Pawel and Morichaud, Zakia and Brodolin, Konstantin and Kapanidis, Achillefs~N.},
