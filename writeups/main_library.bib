  file = {C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\QIT6PSRJ\\2012 - A regulatory role for repeated decoy transcription.pdf}
}

@incollection{legrosVisualizingSubcellularOrganization2012,
  title = {2.6 {{Visualizing Sub-cellular Organization Using Soft X-ray Tomography}}},
  booktitle = {Comprehensive {{Biophysics}}},
  author = {Le Gros, M. A. and Knoechel, C. G. and Uchida, M. and Parkinson, D. Y. and McDermott, G. and Larabell, C. A.},
