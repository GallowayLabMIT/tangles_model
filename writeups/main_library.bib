@article{hagemann-jensenSinglecellRNACounting2020,
  title = {Single-Cell {{RNA}} Counting at Allele and Isoform Resolution Using {{Smart-seq3}}},
  author = {Hagemann-Jensen, Michael and Ziegenhain, Christoph and Chen, Ping and Ramsköld, Daniel and Hendriks, Gert-Jan and Larsson, Anton J. M. and Faridani, Omid R. and Sandberg, Rickard},
  date = {2020-06},
  journaltitle = {Nature Biotechnology},
