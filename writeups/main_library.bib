  author = {Sanborn, Adrian L. and Rao, Suhas S. P. and Huang, Su-Chen and Durand, Neva C. and Huntley, Miriam H. and Jewett, Andrew I. and Bochkov, Ivan D. and Chinnappan, Dharmaraj and Cutkosky, Ashok and Li, Jian and Geeting, Kristopher P. and Gnirke, Andreas and Melnikov, Alexandre and McKenna, Doug and Stamenova, Elena K. and Lander, Eric S. and Aiden, Erez Lieberman},
