@article{galvan-ampudiaTemporalIntegrationAuxin2020,
  title = {Temporal Integration of Auxin Information for the Regulation of Patterning},
  author = {Galvan-Ampudia, Carlos S and Cerutti, Guillaume and Legrand, Jonathan and Brunoud, Géraldine and Martin-Arevalillo, Raquel and Azais, Romain and Bayle, Vincent and Moussu, Steven and Wenzl, Christian and Jaillais, Yvon and Lohmann, Jan U and Godin, Christophe and Vernoux, Teva},
