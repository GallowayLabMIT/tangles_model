  author = {Almassalha, Luay M. and Bauer, Greta M. and Wu, Wenli and Cherkezyan, Lusik and Zhang, Di and Kendra, Alexis and Gladstein, Scott and Chandler, John E. and VanDerway, David and Seagle, Brandon-Luke L. and Ugolkov, Andrey and Billadeau, Daniel D. and O’Halloran, Thomas V. and Mazar, Andrew P. and Roy, Hemant K. and Szleifer, Igal and Shahabi, Shohreh and Backman, Vadim},
  date = {2017-11},
  journaltitle = {Nature Biomedical Engineering},
  volume = {1},
  number = {11},
