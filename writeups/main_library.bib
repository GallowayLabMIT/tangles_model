@article{crowhurstNMRdetectedConformationalExchange2008,
  title = {{{NMR-detected}} Conformational Exchange Observed in a Computationally Designed Variant of Protein {{Gβ1}}},
  author = {Crowhurst, Karin A. and Mayo, Stephen L.},
  date = {2008-09-01},
  journaltitle = {Protein Engineering, Design and Selection},
