  author = {Ichida, Justin K. and Staats, Kim A. and Davis-Dusenbery, Brandi N. and Clement, Kendell and Galloway, Kate E. and Babos, Kimberly N. and Shi, Yingxiao and Son, Esther Y. and Kiskinis, Evangelos and Atwater, Nicholas and Gu, Hongcang and Gnirke, Andreas and Meissner, Alexander and Eggan, Kevin},
  date = {2018-11-15},
  journaltitle = {Development (Cambridge, England)},
