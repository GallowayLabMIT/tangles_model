@article{tevesDNATorsionFeedback2014,
  title = {{{DNA}} Torsion as a Feedback Mediator of Transcription and Chromatin Dynamics},
  author = {Teves, Sheila S. and Henikoff, Steven},
  date = {2014-05-01},
  journaltitle = {Nucleus},
  volume = {5},
  number = {3},
  eprint = {24819949},
  eprinttype = {pmid},
  pages = {211--218},
  publisher = {{Taylor \& Francis}},
  issn = {1949-1034},
  doi = {10.4161/nucl.29086},
  url = {https://doi.org/10.4161/nucl.29086},
  urldate = {2020-07-10},
  abstract = {The double helical structure of DNA lends itself to topological constraints. Many DNA-based processes alter the topological state of DNA, generating torsional stress, which is efficiently relieved by topoisomerases. Maintaining this topological balance is crucial to cell survival, as excessive torsional strain risks DNA damage. Here, we review the mechanisms that generate and modulate DNA torsion within the cell. In particular, we discuss how transcription-generated torsional stress affects Pol II kinetics and chromatin dynamics, highlighting an emerging role of DNA torsion as a feedback mediator of torsion-generating processes.},
  keywords = {nascent RNA,nucleosome turnover,RNA Polymerase II,topoisomerase,torsional stress},
  annotation = {\_eprint: https://doi.org/10.4161/nucl.29086},
