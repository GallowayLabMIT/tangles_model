  author = {Macia, Javier and Manzoni, Romilde and Conde, Núria and Urrios, Arturo and de Nadal, Eulàlia and Solé, Ricard and Posas, Francesc},
  date = {2016-02-01},
  journaltitle = {PLOS Computational Biology},
