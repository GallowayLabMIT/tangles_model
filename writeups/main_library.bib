@article{renHumanArtificialChromosome2006,
  title = {Human Artificial Chromosome Vectors Meet Stem Cells: {{New}} Prospects for Gene Delivery},
  shorttitle = {Human Artificial Chromosome Vectors Meet Stem Cells},
  author = {Ren, Xianying and Tahimic, Candice Ginn T. and Katoh, Motonobu and Kurimasa, Akihiro and Inoue, Toshiaki and Oshimura, Mitsuo},
