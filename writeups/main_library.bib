@article{liSyntheticNeurallikeComputing2021,
  title = {Synthetic Neural-like Computing in Microbial Consortia for Pattern Recognition},
  author = {Li, Ximing and Rizik, Luna and Kravchik, Valeriia and Khoury, Maria and Korin, Netanel and Daniel, Ramez},
  date = {2021-05-25},
