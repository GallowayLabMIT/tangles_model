@article{hathawayDynamicsMemoryHeterochromatin2012,
  title = {Dynamics and {{Memory}} of {{Heterochromatin}} in {{Living Cells}}},
  author = {Hathaway, Nathaniel~A. and Bell, Oliver and Hodges, Courtney and Miller, Erik~L. and Neel, Dana~S. and Crabtree, Gerald~R.},
