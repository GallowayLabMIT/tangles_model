  langid = {english},
  keywords = {Genetic circuit engineering,Growth factor signalling,Synthetic biology},
  annotation = {Bandiera\_abtest: a Cc\_license\_type: cc\_by Cg\_type: Nature Research Journals Primary\_atype: Research Subject\_term: Genetic circuit engineering;Growth factor signalling;Synthetic biology Subject\_term\_id: genetic-circuit-engineering;growth-signalling;synthetic-biology},
