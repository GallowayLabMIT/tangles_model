@article{ravindranEngineeringCombinatorialDynamic2020,
  title = {Engineering Combinatorial and Dynamic Decoders Using Synthetic Immediate-Early Genes},
  author = {Ravindran, Pavithran T. and Wilson, Maxwell Z. and Jena, Siddhartha G. and Toettcher, Jared E.},
  date = {2020-08-13},
  journaltitle = {Communications Biology},
  shortjournal = {Commun Biol},
  volume = {3},
