@article{dolbergComputationguidedOptimizationSplit2021,
  title = {Computation-Guided Optimization of Split Protein Systems},
  author = {Dolberg, Taylor B. and Meger, Anthony T. and Boucher, Jonathan D. and Corcoran, William K. and Schauer, Elizabeth E. and Prybutok, Alexis N. and Raman, Srivatsan and Leonard, Joshua N.},
  date = {2021-02-01},
  journaltitle = {Nature Chemical Biology},
  pages = {1--9},
  publisher = {{Nature Publishing Group}},
  issn = {1552-4469},
  doi = {10.1038/s41589-020-00729-8},
  url = {https://www.nature.com/articles/s41589-020-00729-8},
  urldate = {2021-02-16},
  abstract = {Splitting bioactive proteins into conditionally reconstituting fragments is a powerful strategy for building tools to study and control biological systems. However, split proteins often exhibit a high propensity to reconstitute, even without the conditional trigger, limiting their utility. Current approaches for tuning reconstitution propensity are laborious, context-specific or often ineffective. Here, we report a computational design strategy grounded in fundamental protein biophysics to guide experimental evaluation of a sparse set of mutants to identify an optimal functional window. We hypothesized that testing a limited set of mutants would direct subsequent mutagenesis efforts by predicting desirable mutant combinations from a vast mutational landscape. This strategy varies the degree of interfacial destabilization while preserving stability and catalytic activity. We validate our method by solving two distinct split protein design challenges, generating both design and mechanistic insights. This new technology will streamline the generation and use of split protein systems for diverse applications.},
  langid = {english},
  file = {C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\DN8DXYN7\\Dolberg et al_2021_Computation-guided optimization of split protein systems.pdf;C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\WQAPWWXH\\s41589-020-00729-8.html}
}

