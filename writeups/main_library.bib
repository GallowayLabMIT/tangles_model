@article{barutcuSystematicMappingNuclear2022,
  title = {Systematic Mapping of Nuclear Domain-Associated Transcripts Reveals Speckles and Lamina as Hubs of Functionally Distinct Retained Introns},
  author = {Barutcu, A. Rasim and Wu, Mingkun and Braunschweig, Ulrich and Dyakov, Boris J. A. and Luo, Zheng and Turner, Kyle M. and Durbic, Tanja and Lin, Zhen-Yuan and Weatheritt, Robert J. and Maass, Philipp G. and Gingras, Anne-Claude and Blencowe, Benjamin J.},
  date = {2022-02-18},
  journaltitle = {Molecular Cell},
