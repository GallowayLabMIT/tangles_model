@article{georgeEngineeredStemCell2018,
  title = {Engineered Stem Cell Mimics to Enhance Stroke Recovery},
  author = {George, Paul M. and Oh, Byeongtaek and Dewi, Ruby and Hua, Thuy and Cai, Lei and Levinson, Alexa and Liang, Xibin and Krajina, Brad A. and Bliss, Tonya M. and Heilshorn, Sarah C. and Steinberg, Gary K.},
