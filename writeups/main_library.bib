@article{bedbrookMachineLearningDesign2017,
  title = {Machine Learning to Design Integral Membrane Channelrhodopsins for Efficient Eukaryotic Expression and Plasma Membrane Localization},
  author = {Bedbrook, Claire N. and Yang, Kevin K. and Rice, Austin J. and Gradinaru, Viviana and Arnold, Frances H.},
  date = {2017-10-23},
  journaltitle = {PLOS Computational Biology},
  shortjournal = {PLOS Computational Biology},
  volume = {13},
  number = {10},
  pages = {e1005786},
  issn = {1553-7358},
  doi = {10.1371/journal.pcbi.1005786},
  url = {https://journals.plos.org/ploscompbiol/article?id=10.1371/journal.pcbi.1005786},
  urldate = {2018-09-27},
  abstract = {There is growing interest in studying and engineering integral membrane proteins (MPs) that play key roles in sensing and regulating cellular response to diverse external signals. A MP must be expressed, correctly inserted and folded in a lipid bilayer, and trafficked to the proper cellular location in order to function. The sequence and structural determinants of these processes are complex and highly constrained. Here we describe a predictive, machine-learning approach that captures this complexity to facilitate successful MP engineering and design. Machine learning on carefully-chosen training sequences made by structure-guided SCHEMA recombination has enabled us to accurately predict the rare sequences in a diverse library of channelrhodopsins (ChRs) that express and localize to the plasma membrane of mammalian cells. These light-gated channel proteins of microbial origin are of interest for neuroscience applications, where expression and localization to the plasma membrane is a prerequisite for function. We trained Gaussian process (GP) classification and regression models with expression and localization data from 218 ChR chimeras chosen from a 118,098-variant library designed by SCHEMA recombination of three parent ChRs. We use these GP models to identify ChRs that express and localize well and show that our models can elucidate sequence and structure elements important for these processes. We also used the predictive models to convert a naturally occurring ChR incapable of mammalian localization into one that localizes well.},
  langid = {english},
  keywords = {Cell membranes,Crystal structure,Engineers,Integral membrane proteins,Membrane proteins,Protein sequencing,Signal peptides,Statistical models},
  file = {C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\8VVBERPY\\Bedbrook et al. - 2017 - Machine learning to design integral membrane chann.pdf;C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\P789ZYTA\\article.html;C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\V4D43BIR\\article.html}
}

@article{behrTestingDependenceTree2020,
  title = {Testing for Dependence on Tree Structures},
  author = {Behr, Merle and Ansari, M. Azim and Munk, Axel and Holmes, Chris},
  date = {2020-05-05},
