@article{yangLncRNAfuncKnowledgebaseLncRNA2022,
  title = {{{lncRNAfunc}}: A Knowledgebase of {{lncRNA}} Function in Human Cancer},
  shorttitle = {{{lncRNAfunc}}},
  author = {Yang, Mengyuan and Lu, Huifen and Liu, Jiajia and Wu, Sijia and Kim, Pora and Zhou, Xiaobo},
  date = {2022-01-07},
  journaltitle = {Nucleic Acids Research},
  shortjournal = {Nucleic Acids Research},
