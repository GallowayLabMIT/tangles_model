}

@article{hoencamp3DGenomicsTree2021,
  title = {{{3D}} Genomics across the Tree of Life Reveals Condensin {{II}} as a Determinant of Architecture Type},
  author = {Hoencamp, Claire and Dudchenko, Olga and Elbatsh, Ahmed M. O. and Brahmachari, Sumitabha and Raaijmakers, Jonne A. and van Schaik, Tom and Cacciatore, Ángela Sedeño and Contessoto, Vinícius G. and van Heesbeen, Roy G. H. P. and van den Broek, Bram and Mhaskar, Aditya N. and Teunissen, Hans and Hilaire, Brian Glenn St and Weisz, David and Omer, Arina D. and Pham, Melanie and Colaric, Zane and Yang, Zhenzhen and Rao, Suhas S. P. and Mitra, Namita and Lui, Christopher and Yao, Weijie and Khan, Ruqayya and Moroz, Leonid L. and Kohn, Andrea and Leger, Judy St and Mena, Alexandria and Holcroft, Karen and Gambetta, Maria Cristina and Lim, Fabian and Farley, Emma and Stein, Nils and Haddad, Alexander and Chauss, Daniel and Mutlu, Ayse Sena and Wang, Meng C. and Young, Neil D. and Hildebrandt, Evin and Cheng, Hans H. and Knight, Christopher J. and Burnham, Theresa L. U. and Hovel, Kevin A. and Beel, Andrew J. and Mattei, Pierre-Jean and Kornberg, Roger D. and Warren, Wesley C. and Cary, Gregory and Gómez-Skarmeta, José Luis and Hinman, Veronica and Lindblad-Toh, Kerstin and Palma, Federica Di and Maeshima, Kazuhiro and Multani, Asha S. and Pathak, Sen and Nel-Themaat, Liesl and Behringer, Richard R. and Kaur, Parwinder and Medema, René H. and van Steensel, Bas and de Wit, Elzo and Onuchic, José N. and Pierro, Michele Di and Aiden, Erez Lieberman and Rowland, Benjamin D.},
  date = {2021-05-28},
  journaltitle = {Science},
  volume = {372},
  number = {6545},
  eprint = {34045355},
  eprinttype = {pmid},
  pages = {984--989},
  publisher = {{American Association for the Advancement of Science}},
  issn = {0036-8075, 1095-9203},
  doi = {10.1126/science.abe2218},
  url = {https://science.sciencemag.org/content/372/6545/984},
  urldate = {2021-05-28},
  abstract = {Organismal evolution of the 3D genome The conformation of chromosomes within the nucleus can reflect a cell's type or state. However, studies of the conservation and evolutionary history of the mechanisms regulating genome structure across species are lacking. Hoencamp et al. mapped three-dimensional (3D) genome organization in 24 eukaryote species, including animals, fungi, and plants. At interphase, species' telomeres and centromeres either clustered across chromosomes or oriented in a polarized state maintaining individual chromosomal territories within the cell, a difference attributed to condensin II. An experimental loss of condensin II in human cells promotes the formation of centromere clusters but has no effect on loop or compartment formation. Whether the structure of the 3D genome varies across species may thus depend on whether they carry a functional condensin II gene. Science, abe2218, this issue p. 984 We investigated genome folding across the eukaryotic tree of life. We find two types of three-dimensional (3D) genome architectures at the chromosome scale. Each type appears and disappears repeatedly during eukaryotic evolution. The type of genome architecture that an organism exhibits correlates with the absence of condensin II subunits. Moreover, condensin II depletion converts the architecture of the human genome to a state resembling that seen in organisms such as fungi or mosquitoes. In this state, centromeres cluster together at nucleoli, and heterochromatin domains merge. We propose a physical model in which lengthwise compaction of chromosomes by condensin II during mitosis determines chromosome-scale genome architecture, with effects that are retained during the subsequent interphase. This mechanism likely has been conserved since the last common ancestor of all eukaryotes. A cross-species comparison suggests that condensin II underlies chromosome-scale genome organization in eukaryotes. A cross-species comparison suggests that condensin II underlies chromosome-scale genome organization in eukaryotes.},
  langid = {english},
  keywords = {unread},
  file = {C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\BG2W5HHL\\Hoencamp et al_2021_3D genomics across the tree of life reveals condensin II as a determinant of.pdf;C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\X2Q862FC\\984.html}
}

