@article{fernandopulleTranscriptionFactorMediated2018,
  title = {Transcription {{Factor}}–{{Mediated Differentiation}} of {{Human iPSCs}} into {{Neurons}}},
  author = {Fernandopulle, Michael S. and Prestil, Ryan and Grunseich, Christopher and Wang, Chao and Gan, Li and Ward, Michael E.},
  date = {2018},
  journaltitle = {Current Protocols in Cell Biology},
