@article{udemFemtosecondOpticalFrequency2009,
  title = {Femtosecond Optical Frequency Combs},
  author = {Udem, Th. and Holzwarth, R. and Hänsch, Th.},
  date = {2009-06-01},
  journaltitle = {The European Physical Journal Special Topics},
