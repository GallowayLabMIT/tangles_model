  date = {2022-04-25},
  journaltitle = {Nature Methods},
  shortjournal = {Nat Methods},
  pages = {1--7},
  publisher = {{Nature Publishing Group}},
  issn = {1548-7105},
  doi = {10.1038/s41592-022-01446-x},
  url = {https://www.nature.com/articles/s41592-022-01446-x},
  urldate = {2022-04-26},
  abstract = {Single-cell sequencing methods rely on molecule-counting strategies to account for amplification biases, yet no experimental strategy to evaluate counting performance exists. Here, we introduce molecular spikes—RNA spike-ins containing built-in unique molecular identifiers (UMIs) that we use to identify critical experimental and computational conditions for accurate RNA counting in single-cell RNA-sequencing (scRNA-seq). Using molecular spikes, we uncovered impaired RNA counting in methods that were not informative for cellular RNA abundances due to inflated UMI counts. We further leverage molecular spikes to improve estimates of total endogenous RNA amounts in cells, and introduce a strategy to correct experiments with impaired RNA counting. The molecular spikes and the accompanying R package UMIcountR (https://github.com/cziegenhain/UMIcountR) will improve the validation of new methods, better estimate and adjust for cellular mRNA amounts and enable more indepth characterization of RNA counting in scRNA-seq.},
  langid = {english},
  keywords = {Gene expression,RNA sequencing},
  file = {C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\68ZDMXCN\\Ziegenhain et al_2022_Molecular spikes.pdf;C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\LX4CMXMI\\s41592-022-01446-x.html}
}

@article{zimmerSTLseqRevealsPauserelease2021,
  title = {{{STL-seq}} Reveals Pause-Release and Termination Kinetics for Promoter-Proximal Paused {{RNA}} Polymerase {{II}} Transcripts},
  author = {Zimmer, Joshua T. and Rosa-Mercado, Nicolle A. and Canzio, Daniele and Steitz, Joan A. and Simon, Matthew D.},
  date = {2021-09-13},
  journaltitle = {Molecular Cell},
  shortjournal = {Molecular Cell},
  issn = {1097-2765},
  doi = {10.1016/j.molcel.2021.08.019},
  url = {https://www.sciencedirect.com/science/article/pii/S1097276521006869},
  urldate = {2021-09-14},
  abstract = {Despite the critical regulatory function of promoter-proximal pausing, the influence of pausing kinetics on transcriptional control remains an active area of investigation. Here, we present Start-TimeLapse-seq (STL-seq), a method that captures the genome-wide kinetics of short, capped RNA turnover and reveals principles of regulation at the pause site. By measuring the rates of release into elongation and premature termination through the inhibition of pause release, we determine that pause-release rates are highly variable, and most promoter-proximal paused RNA polymerase II molecules prematurely terminate (∼80\%). The preferred regulatory mechanism upon a hormonal stimulus (20-hydroxyecdysone) is to influence pause-release rather than termination rates. Transcriptional shutdown occurs concurrently with the induction of promoter-proximal termination under hyperosmotic stress, but paused transcripts from TATA box-containing promoters remain stable, demonstrating an important role for cis-acting DNA elements in pausing. STL-seq dissects the kinetics of pause release and termination, providing an opportunity to identify mechanisms of transcriptional regulation.},
  langid = {english},
  keywords = {premature termination,promoter-proximal pausing,release into elongation,scRNA,STL-seq,TimeLapse},
  file = {C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\26DJMTLA\\S1097276521006869.html}
}

@article{zinaniPairingSegmentationClock2020,
  title = {Pairing of Segmentation Clock Genes Drives Robust Pattern Formation},
  author = {Zinani, Oriana Q. H. and Keseroğlu, Kemal and Ay, Ahmet and Özbudak, Ertuğrul M.},
  date = {2020-12-23},
  journaltitle = {Nature},
  number = {7842},
  pages = {1--6},
  publisher = {{Nature Publishing Group}},
  issn = {1476-4687},
  doi = {10.1038/s41586-020-03055-0},
  url = {https://www.nature.com/articles/s41586-020-03055-0},
  urldate = {2021-01-04},
  abstract = {Gene expression is an inherently stochastic process1,2; however, organismal development and homeostasis require cells to coordinate the spatiotemporal expression of large sets of genes. In metazoans, pairs of co-expressed genes often reside in the same chromosomal neighbourhood, with gene pairs representing 10 to 50\% of all genes, depending on the species3–6. Because shared upstream regulators can ensure correlated gene expression, the selective advantage of maintaining adjacent gene pairs remains unknown6. Here, using two linked zebrafish segmentation clock genes, her1 and her7, and combining single-cell transcript counting, genetic engineering, real-time imaging and computational modelling, we show that gene pairing boosts correlated transcription and provides phenotypic robustness for the formation of developmental patterns. Our results demonstrate that the prevention of gene pairing disrupts oscillations and segmentation, and the linkage of her1 and her7 is essential for the development of the body axis in zebrafish embryos. We predict that gene pairing may be similarly advantageous in other organisms, and our findings could lead to the engineering of precise synthetic clocks in embryos and organoids.},
  langid = {english},
  keywords = {phd_proposal},
  file = {C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\4A6RW47B\\Zinani et al_2020_Pairing of segmentation clock genes drives robust pattern formation.pdf;C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\ILDHNHCK\\Zinani et al_2021_Pairing of segmentation clock genes drives robust pattern formation.pdf;C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\DDXDTWQ8\\s41586-020-03055-0.html;C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\I8RIM3DE\\s41586-020-03055-0.html}
}

