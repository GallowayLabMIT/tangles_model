@report{benzingerSyntheticGeneNetworks2021,
  type = {preprint},
  title = {Synthetic Gene Networks Recapitulate Dynamic Signal Decoding and Differential Gene Expression},
  author = {Benzinger, Dirk and Ovinnikov, Serguei and Khammash, Mustafa},
