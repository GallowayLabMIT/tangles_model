@article{sinhaEDF1CoordinatesCellular2020,
  title = {{{EDF1}} Coordinates Cellular Responses to Ribosome Collisions},
  author = {Sinha, Niladri K and Ordureau, Alban and Best, Katharina and Saba, James A and Zinshteyn, Boris and Sundaramoorthy, Elayanambi and Fulzele, Amit and Garshott, Danielle M and Denk, Timo and Thoms, Matthias and Paulo, Joao A and Harper, Wade and Bennett, Eric J and Beckmann, Roland and Green, Rachel},
