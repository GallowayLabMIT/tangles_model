@article{doshiMultipleAlternativePromoters2020,
  title = {Multiple {{Alternative Promoters}} and {{Alternative Splicing Enable Universal Transcription-Based Logic Computation}} in {{Mammalian Cells}}},
  author = {Doshi, Jiten and Willis, Katie and Madurga, Angela and Stelzer, Christoph and Benenson, Yaakov},
