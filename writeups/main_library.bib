@article{al-radhawiIdentifyingCompetitionPhenotypes2022,
  title = {Identifying Competition Phenotypes in Synthetic Biochemical Circuits},
  author = {Al-Radhawi, Muhammad Ali and Vecchio, Domitilla Del and Sontag, Eduardo},
  date = {2022-03-23},
