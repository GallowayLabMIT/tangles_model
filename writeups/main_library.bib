@article{liChromatinAccessibilityDynamics2017,
  title = {Chromatin {{Accessibility Dynamics}} during {{iPSC Reprogramming}}},
  author = {Li, Dongwei and Liu, Jing and Yang, Xuejie and Zhou, Chunhua and Guo, Jing and Wu, Chuman and Qin, Yue and Guo, Lin and He, Jiangping and Yu, Shenyong and Liu, He and Wang, Xiaoshan and Wu, Fang and Kuang, Junqi and Hutchins, Andrew P. and Chen, Jiekai and Pei, Duanqing},
  date = {2017-12-07},
  journaltitle = {Cell Stem Cell},
  shortjournal = {Cell Stem Cell},
  volume = {21},
  number = {6},
  pages = {819-833.e6},
  issn = {1934-5909},
  doi = {10.1016/j.stem.2017.10.012},
  url = {http://www.sciencedirect.com/science/article/pii/S1934590917304290},
  urldate = {2020-04-28},
  abstract = {Cell-fate decisions remain poorly understood at the chromatin level. Here, we map chromatin remodeling dynamics during induction of pluripotent stem cells. ATAC-seq profiling of MEFs expressing Oct4-Sox2-Klf4 (OSK) reveals dynamic changes in chromatin states shifting from open to closed (OC) and closed to open (CO), with an initial burst of OC and an ending surge of CO. The OC loci are largely composed of genes associated with a somatic fate, while the CO loci are associated with pluripotency. Factors/conditions known to impede reprogramming prevent OSK-driven OC and skew OC-CO dynamics. While the CO loci are enriched for OSK motifs, the OC loci are not, suggesting alternative mechanisms for chromatin closing. Sap30, a Sin3A corepressor complex component, is required for the OC shift and facilitates reduced H3K27ac deposition at OC loci. These results reveal a chromatin accessibility logic during reprogramming that may apply to other cell-fate decisions.},
  langid = {english},
  keywords = {binary logic,chromatin dynamics,open/close,reprogramming,Sap30},
  file = {C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\YK2QQ94Y\\Li et al_2017_Chromatin Accessibility Dynamics during iPSC Reprogramming.pdf}
}

@report{liChromatinaccessibilityEstimationSinglecell2019,
  type = {preprint},
  title = {Chromatin-Accessibility Estimation from Single-Cell {{ATAC}} Data with {{scOpen}}},
  author = {Li, Zhijian and Kuppe, Christoph and Ziegler, Susanne and Cheng, Mingbo and Kabgani, Nazanin and Menzel, Sylvia and Zenke, Martin and Kramann, Rafael and Costa, Ivan G.},
