@article{mcbridePredictingCompositionGenetic2021,
  title = {Predicting {{Composition}} of {{Genetic Circuits}} with {{Resource Competition}}: {{Demand}} and {{Sensitivity}}},
  shorttitle = {Predicting {{Composition}} of {{Genetic Circuits}} with {{Resource Competition}}},
  author = {McBride, Cameron D. and Vecchio, Domitilla Del},
  date = {2021-05-27},
  journaltitle = {bioRxiv},
  pages = {2021.05.26.445862},
  publisher = {{Cold Spring Harbor Laboratory}},
  doi = {10.1101/2021.05.26.445862},
  url = {https://www.biorxiv.org/content/10.1101/2021.05.26.445862v1},
  urldate = {2021-05-28},
  abstract = {{$<$}p{$>$}The design of genetic circuits typically relies on characterization of constituent modules in isolation to predict the behavior of modules9 composition. However, it has been shown that the behavior of a genetic module changes when other modules are in the cell due to competition for shared resources. In order to engineer multi-module circuits that behave as intended, it is thus necessary to predict changes in the behavior of a genetic module when other modules load cellular resources. Here, we introduce two characteristics of circuit modules: the demand for cellular resources and the sensitivity to resource loading. When both are known for every genetic module in a circuit, they can be used to predict any module9s behavior upon addition of any other module to the cell. We develop an experimental approach to measure both characteristics for any circuit module using a resource sensor module. Using the measured resource demand and sensitivity for each module in a library, the outputs of the modules can be accurately predicted when they are inserted in the cell in arbitrary combinations. These resource competition characteristics may be used to inform the design of genetic circuits that perform as predicted despite resource competition.{$<$}/p{$>$}},
  langid = {english},
  keywords = {unread},
  file = {C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\W9GSTMZU\\McBride_Vecchio_2021_Predicting Composition of Genetic Circuits with Resource Competition.pdf;C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\GQW789ES\\2021.05.26.html}
}

@article{mcbridePredictingCompositionGenetic2021a,
  title = {Predicting {{Composition}} of {{Genetic Circuits}} with {{Resource Competition}}: {{Demand}} and {{Sensitivity}}},
  shorttitle = {Predicting {{Composition}} of {{Genetic Circuits}} with {{Resource Competition}}},
  author = {McBride, Cameron D. and Del Vecchio, Domitilla},
  date = {2021-11-15},
  journaltitle = {ACS Synthetic Biology},
  shortjournal = {ACS Synth. Biol.},
  publisher = {{American Chemical Society}},
  doi = {10.1021/acssynbio.1c00281},
  url = {https://doi.org/10.1021/acssynbio.1c00281},
  urldate = {2021-11-17},
  abstract = {The design of genetic circuits typically relies on characterization of constituent modules in isolation to predict the behavior of modules’ composition. However, it has been shown that the behavior of a genetic module changes when other modules are in the cell due to competition for shared resources. In order to engineer multimodule circuits that behave as intended, it is thus necessary to predict changes in the behavior of a genetic module when other modules load cellular resources. Here, we introduce two characteristics of circuit modules: the demand for cellular resources and the sensitivity to resource loading. When both are known for every genetic module in a circuit library, they can be used to predict any module’s behavior upon addition of any other module to the cell. We develop an experimental approach to measure both characteristics for any circuit module using a resource sensor module. Using the measured resource demand and sensitivity for each module in a library, the outputs of the modules can be accurately predicted when they are inserted in the cell in arbitrary combinations. These resource competition characteristics may be used to inform the design of genetic circuits that perform as predicted despite resource competition.},
  keywords = {unread},
  file = {C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\YWHUGK3G\\McBride_Del Vecchio_2021_Predicting Composition of Genetic Circuits with Resource Competition.pdf;C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\NK6GDU3A\\acssynbio.html}
}

@article{mcclementsAdenoassociatedVirusAAV2017,
  title = {Adeno-Associated {{Virus}} ({{AAV}}) {{Dual Vector Strategies}} for {{Gene Therapy Encoding Large Transgenes}}},
  author = {McClements, Michelle E. and MacLaren, Robert E.},
  date = {2017-12-19},
  journaltitle = {The Yale Journal of Biology and Medicine},
  shortjournal = {Yale J Biol Med},
  volume = {90},
  number = {4},
  eprint = {29259525},
  eprinttype = {pmid},
  pages = {611--623},
  issn = {0044-0086},
  url = {https://www.ncbi.nlm.nih.gov/pmc/articles/PMC5733846/},
  urldate = {2022-03-15},
  abstract = {The use of adeno-associated viral (AAV) vectors for gene therapy treatments of inherited disorders has accelerated over the past decade with multiple clinical trials ongoing in varying tissue types and new ones initiating every year. These vectors are exhibiting low-immunogenicity across the clinical trials in addition to showing evidence of efficacy, making it clear they are the current standard vector for any potential gene therapy treatment. However, AAV vectors do have a limitation in their packaging capacity, being capable of holding no more than \textasciitilde 5kb of DNA and in a therapeutic transgene scenario, this length of DNA would need to include genetic control elements in addition to the gene coding sequence (CDS) of interest. Given that numerous diseases are caused by mutations in genes with a CDS exceeding 3.5kb, this makes packaging into a single AAV capsid not possible for larger genes. Due to this problem, yet with the desire to use AAV vectors, research groups have adapted the standard AAV gene therapy approach to enable delivery of such large genes to target cells using dual AAV vector systems. Here we review the AAV dual vector strategies currently employed and highlight the virtues and drawbacks of each method plus the likelihood of success with such approaches.},
  pmcid = {PMC5733846},
  file = {C\:\\Users\\ChemeGrad2019\\Zotero\\storage\\U4Y2IHJD\\McClements_MacLaren_2017_Adeno-associated Virus (AAV) Dual Vector Strategies for Gene Therapy Encoding.pdf}
}

