}

@article{berrymanImagebasedPhenotypingDisaggregated2020,
  title = {Image-Based Phenotyping of Disaggregated Cells Using Deep Learning},
  author = {Berryman, Samuel and Matthews, Kerryn and Lee, Jeong Hyun and Duffy, Simon P. and Ma, Hongshen},
  date = {2020-11-13},
