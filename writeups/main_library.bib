@article{bernardSolutionStructureTransient2005,
  title = {The {{Solution Structure}} of a {{Transient Photoreceptor Intermediate}}: {{Δ25 Photoactive Yellow Protein}}},
  shorttitle = {The {{Solution Structure}} of a {{Transient Photoreceptor Intermediate}}},
  author = {Bernard, Cédric and Houben, Klaartje and Derix, Nocky M. and Marks, David and van der Horst, Michael A. and Hellingwerf, Klaas J. and Boelens, Rolf and Kaptein, Robert and van Nuland, Nico A. J.},
