}

@article{townshendGeometricDeepLearning2021,
  title = {Geometric Deep Learning of {{RNA}} Structure},
  author = {Townshend, Raphael J. L. and Eismann, Stephan and Watkins, Andrew M. and Rangan, Ramya and Karelina, Maria and Das, Rhiju and Dror, Ron O.},
  date = {2021-08-27},
  journaltitle = {Science},
  volume = {373},
  number = {6558},
